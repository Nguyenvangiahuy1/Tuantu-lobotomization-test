local function applyAllDamageToWeapons()
	pcall(function()
		local character = LocalPlayer.Character
		if character then
			for _, child in ipairs(character:GetChildren()) do
				if child:IsA("Tool") then
					pcall(function()
						local damage = child:FindFirstChild("Damage")
						if damage and damage:IsA("IntValue") then
							damage.Value = math.random(dmgMin, dmgMax)
