-- ==========================================
-- UTILITY FUNCTIONS
-- ==========================================
local function listChildren(folder)
	local t = {}
	if folder and typeof(folder) == 'Instance' then
		pcall(function()
			for _, v in ipairs(folder:GetChildren()) do
				table.insert(t, v.Name)
			end
		end)
	end
	table.sort(t)
	return t
end

local function getFolder(root, ...)
	if not root then return nil end
	local cur = root
	for i = 1, select('#', ...) do
		local n = select(i, ...)
		if not cur then return nil end
		cur = pcall(function() return cur:FindFirstChild(n) end) and cur:FindFirstChild(n) or nil
		if not cur then return nil end
	end
	return cur
end

local function normalizeSelected(v)
	if type(v) == 'string' then return v end
	if typeof(v) == 'Instance' then return v.Name end
	if type(v) == 'table' then
		if v[1] then return v[1] end
		if v.Name then return v.Name end
	end
	return tostring(v)
end

local function titleCase(s)
	if not s or #s == 0 then return '' end
	return string.upper(string.sub(s, 1, 1)) .. string.lower(string.sub(s, 2))
end

local function getTableLength(t)
	local count = 0
	if type(t) == 'table' then
		for _ in pairs(t) do count = count + 1 end
	end
	return count
end

-- Safe wait for children
local function safeWaitForChild(parent, name, timeout)
	if not parent then return nil end
	timeout = timeout or 3
	local result = nil
	pcall(function()
		result = parent:WaitForChild(name, timeout)
	end)
	return result
end

-- Get best work type based on abnormality stats
local function getBestWorkType(abnoFolder, abnoNames)
	local workStats = {
		Instinct = 0,
		Insight = 0,
		Attachment = 0,
		Repression = 0
	}
	local validCount = 0
	
	for _, abnoName in ipairs(abnoNames) do
		local sel = normalizeSelected(abnoName)
		local abno = nil
		pcall(function()
			abno = abnoFolder:FindFirstChild(sel)
		end)
		
		if abno then
			-- Check HP to determine strength
			local hp = nil
			pcall(function()
				hp = abno:FindFirstChild('HP')
			end)
			
			local hpValue = 0
			if hp and hp:IsA('IntValue') then
				hpValue = hp.Value
				validCount = validCount + 1
			end
			
			-- Analyze work preferences
			local workTablet = nil
			pcall(function()
				workTablet = abno:FindFirstChild('WorkTablet')
			end)
			
			if workTablet then
				-- Get resistance/affinity data if available
				local instinctAffinity = 0
				local insightAffinity = 0
				local attachmentAffinity = 0
				local repressionAffinity = 0
				
				pcall(function()
					instinctAffinity = tonumber(workTablet:GetAttribute("InstinctAffinity") or 0) or 0
					insightAffinity = tonumber(workTablet:GetAttribute("InsightAffinity") or 0) or 0
					attachmentAffinity = tonumber(workTablet:GetAttribute("AttachmentAffinity") or 0) or 0
					repressionAffinity = tonumber(workTablet:GetAttribute("RepressionAffinity") or 0) or 0
				end)
				
				-- Combine HP and affinity to determine best work
				if hpValue > 600 then
					-- Strong enemy - use Repression or Attachment
					if repressionAffinity > attachmentAffinity then
						workStats.Repression = workStats.Repression + 1
					else
						workStats.Attachment = workStats.Attachment + 1
					end
				elseif hpValue > 300 then
					-- Medium enemy - use Insight
					workStats.Insight = workStats.Insight + 1
				else
					-- Weak enemy - use Instinct
					workStats.Instinct = workStats.Instinct + 1
				end
			end
		end
	end
	
	-- Find best work type
	local bestWork = 'Instinct'
	local maxScore = workStats.Instinct
	
	for workType, score in pairs(workStats) do
		if score > maxScore then
			maxScore = score
			bestWork = workType
		end
	end
	
	return bestWork
end

